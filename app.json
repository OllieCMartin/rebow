{
  "expo": {
    "name": "Rebow",
    "slug": "rebow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7EAEC4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rebow.app",
      "infoPlist": {
        "NSMotionUsageDescription": "Rebow needs accelerometer access to track your exercise movements."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7EAEC4"
      },
      "package": "com.rebow.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png",
      "name": "Rebow",
      "shortName": "Rebow",
      "description": "Track your exercises with motion sensing",
      "themeColor": "#7EAEC4",
      "backgroundColor": "#7EAEC4",
      "lang": "en"
    },
    "plugins": [
      "expo-sensors",
      "expo-asset"
    ]
  }
}
